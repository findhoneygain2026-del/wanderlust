<nav class="navbar sticky top-0 z-50 bg-white border-b border-gray-300">
  <div class="mx-auto max-w-7xl px-4 h-auto sm:h-20 flex flex-col sm:flex-row items-center justify-between py-3 sm:py-0">
    
    <div class="flex w-full sm:w-auto items-center justify-between">
      <div class="flex items-center">
        <a href="/listings"><i class="fa-solid fa-hotel text-3xl text-[#fe424fb4]"></i></a>
        <a href="/listings" class="ml-4 rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-300">Explore</a>
      </div>
      <button id="mobile-menu-btn" type="button" class="sm:hidden p-2 text-gray-500 hover:bg-gray-300 rounded-md">
        <svg id="hamburger-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-6 block"><path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
        <svg id="cross-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-6 hidden"><path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </button>
    </div>

    <div class="w-full sm:flex-1 sm:max-w-md px-0 sm:px-4 mt-3 sm:mt-0">
      <form class="flex gap-2" action="/listings" method="GET">
        <div class="relative flex-grow">
          <div class="absolute inset-y-0 start-0 flex items-center ps-3.5 pointer-events-none">
            <i class="fa-solid fa-magnifying-glass text-gray-400"></i>
          </div>
          <input type="search" id="search" name="search" class="w-full p-2.5 ps-10 text-sm border border-gray-200 rounded-3xl bg-gray-50 shadow-sm" placeholder="Search destinations" required />
        </div>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm px-5 py-2.5 rounded-3xl">Search</button>
      </form>
    </div>

    <div class="hidden sm:flex items-center space-x-4">
      <a href="/listings/new" class="text-sm font-medium text-gray-700 hover:bg-gray-300 p-2 rounded">Add Listing</a>
      <% if(!currentUser){ %>
        <a href="/signup" class="text-sm font-medium text-gray-700"><b>Sign Up</b></a>
        <a href="/login" class="text-sm font-medium text-gray-700"><b>Log In</b></a>
      <% } else { %>
        <a href="/logout" class="text-sm font-medium text-gray-700"><b>Log Out</b></a>
      <% } %>
    </div>
  </div>

  <div id="mobile-menu" class="hidden sm:hidden bg-gray-100 border-t border-gray-300 p-4">
    <div class="space-y-2">
      <a href="/listings/new" class="block">Add Listing</a>
      <% if(!currentUser){ %>
        <a href="/signup" class="block">Sign Up</a>
        <a href="/login" class="block">Log In</a>
      <% } else { %>
        <a href="/logout" class="block">Log Out</a>
      <% } %>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const crossIcon = document.getElementById('cross-icon');

  menuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
    hamburgerIcon.classList.toggle('hidden');
    hamburgerIcon.classList.toggle('block');
    crossIcon.classList.toggle('hidden');
    crossIcon.classList.toggle('block');
  });
</script>