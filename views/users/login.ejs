<% layout('/layouts/boilerplate') %>

<div class="flex justify-center items-center min-h-[calc(100vh-100px)] px-4 py-6">
    <div class="w-full max-w-xl bg-white p-6 rounded-lg shadow-sm border border-gray-100">
        <h3 class="text-3xl font-bold mb-6 text-gray-800">Login</h3>
        
        <form method="POST" action="/login" class="space-y-4 needs-validation" novalidate>
            
            <div class="form-group">
                <label for="username" class="block text-md font-medium text-gray-700 mb-1">Username</label>
                <input type="text" id="username" name="username" placeholder="Enter username" required
                       class="form-input w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-200 transition">
                <div class="invalid-feedback hidden text-sm text-red-500 mt-1">Please enter a valid username.</div>
            </div>
            
            <div class="form-group">
                <label for="password" class="block text-md font-medium text-gray-700 mb-1">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter password" required
                       class="form-input w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-200 transition">
            </div>
            
            <div class="pt-2">
                <button type="submit" class="w-full md:w-auto px-6 py-2.5 bg-green-500 text-white font-semibold rounded-md shadow hover:bg-green-600 active:bg-green-700 transition duration-200">
                    Login
                </button>
            </div>
            
        </form>
    </div>
</div>